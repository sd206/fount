# Firebase Admin SDK
# No key file needed — uses Application Default Credentials on Cloud Run.
# For local dev run: gcloud auth application-default login
FIREBASE_STORAGE_BUCKET=fount-app-prod-fb.appspot.com

# AI Providers (use Secret Manager in production — never commit real keys)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# Pinecone
PINECONE_API_KEY=...

# Server
PORT=8080
CORS_ORIGIN=https://app.fount.app
NODE_ENV=development
