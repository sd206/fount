{
  "name": "fount",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:api": "yarn workspace @fount/api dev",
    "dev:web": "yarn workspace @fount/web dev",
    "build:api": "yarn workspace @fount/api build",
    "build:web": "yarn workspace @fount/web build",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  }
}
